#!/usr/bin/env node

const { Server } = require("@modelcontextprotocol/sdk/server/index.js");
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js");
const { CallToolRequestSchema, ListToolsRequestSchema } = require("@modelcontextprotocol/sdk/types.js");
const { execFile, spawn } = require("child_process");
const path = require("path");
const util = require("util");

const execFileAsync = util.promisify(execFile);
const zGmailScript = path.join(__dirname, "z-gmail");

const server = new Server(
  {
    name: "mcp-gmail",
    version: "1.0.0",
  },
  {
    capabilities: {
      tools: {},
    },
  }
);

server.setRequestHandler(ListToolsRequestSchema, async () => {
  return {
    tools: [
      {
        name: "gmail_list_folders",
        description: "List system folders in Gmail.",
        inputSchema: {
          type: "object",
          properties: {},
          required: [],
        },
      },
      {
        name: "gmail_list_tags",
        description: "List user tags in Gmail.",
        inputSchema: {
          type: "object",
          properties: {},
          required: [],
        },
      },
      {
        name: "gmail_search",
        description: "Search emails and show IDs.",
        inputSchema: {
          type: "object",
          properties: {
            query: { type: "string", description: "Gmail search query" },
            limit: { type: "number", description: "Max results to show (default 10)" },
            sort: { type: "string", description: "Sort order (date-desc, date-asc, default date-desc)" },
          },
          required: ["query"],
        },
      },
      {
        name: "gmail_count",
        description: "Count total emails matching query.",
        inputSchema: {
          type: "object",
          properties: {
            query: { type: "string", description: "Gmail search query" },
          },
          required: ["query"],
        },
      },
      {
        name: "gmail_read",
        description: "Read email content and print as markdown",
        inputSchema: {
          type: "object",
          properties: {
            id: { type: "string", description: "Email ID" },
          },
          required: ["id"],
        },
      },
      {
        name: "gmail_download",
        description: "Download email by ID as .eml file.",
        inputSchema: {
          type: "object",
          properties: {
            id: { type: "string", description: "Email ID" },
          },
          required: ["id"],
        },
      },
      {
        name: "gmail_move",
        description: "Move an email from one folder/label to another.",
        inputSchema: {
          type: "object",
          properties: {
            id: { type: "string", description: "Email ID" },
            fromLabel: { type: "string", description: "Source folder/label ID (e.g., INBOX)" },
            toLabel: { type: "string", description: "Destination folder/label ID (e.g., TRASH)" },
          },
          required: ["id", "fromLabel", "toLabel"],
        },
      },
      {
        name: "gmail_delete_all",
        description: "Recursively delete emails matching query.",
        inputSchema: {
          type: "object",
          properties: {
            query: { type: "string", description: "Gmail search query for deletion" },
          },
          required: ["query"],
        },
      },
    ],
  };
});

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;

  try {
    let stdout = "";
    let stderr = "";

    if (name === "gmail_list_folders") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "list-folders"]);
      stdout = result.stdout;
    } else if (name === "gmail_list_tags") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "list-tags"]);
      stdout = result.stdout;
    } else if (name === "gmail_search") {
      const cmdArgs = [zGmailScript, "search", "-q", args.query];
      if (args.limit) {
        cmdArgs.push("-n", args.limit.toString());
      }
      if (args.sort) {
        cmdArgs.push("-s", args.sort);
      }
      const result = await execFileAsync(process.execPath, cmdArgs);
      stdout = result.stdout;
    } else if (name === "gmail_count") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "count", "-q", args.query]);
      stdout = result.stdout;
    } else if (name === "gmail_read") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "read", args.id]);
      stdout = result.stdout;
    } else if (name === "gmail_download") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "download", args.id]);
      stdout = result.stdout;
    } else if (name === "gmail_move") {
      const result = await execFileAsync(process.execPath, [zGmailScript, "move", args.id, args.fromLabel, args.toLabel]);
      stdout = result.stdout;
    } else if (name === "gmail_delete_all") {
      // For delete-all, we need to bypass the interactive prompt by piping "yes\n"
      stdout = await new Promise((resolve, reject) => {
        const child = spawn(process.execPath, [zGmailScript, "delete-all", "-q", args.query]);
        let out = "";
        let err = "";

        child.stdout.on("data", (data) => {
          out += data.toString();
        });

        child.stderr.on("data", (data) => {
          err += data.toString();
        });

        child.on("close", (code) => {
          if (code === 0) {
            resolve(out);
          } else {
            reject(new Error(`Process exited with code ${code}. Stderr: ${err}`));
          }
        });

        child.stdin.write("yes\n");
        child.stdin.end();
      });
    } else {
      throw new Error(`Tool not found: ${name}`);
    }

    return {
      content: [{ type: "text", text: stdout }],
    };
  } catch (error) {
    return {
      content: [{ type: "text", text: `Error executing tool: ${error.message}` }],
      isError: true,
    };
  }
});

async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

main().catch(console.error);
