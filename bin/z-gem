#!/usr/bin/env node

const fs = require("fs");
const { GoogleGenerativeAI } = require("@google/generative-ai");
const path = require("path");
const os = require("os");
const readline = require("readline"); // Added readline module

// Load .env from the user's home directory
require("dotenv").config({ path: path.join(os.homedir(), ".env"), quiet: true });

// Load API key and model from environment variables
const apiKey = process.env.GEMINI_API_KEY;
const modelName = process.env.GEMINI_MODEL || "gemini-2.0-flash";

if (!apiKey) {
  console.error("Error: GEMINI_API_KEY is not set in your ~/.env file.");
  process.exit(1);
}

// Determine template file path
const defaultTemplatePath = path.join(os.homedir(), ".z-gems", "tech-english-teacher"); // Corrected to .z-gems
const templatePath = process.argv[2] || defaultTemplatePath;

let systemInstruction = "";
try {
  systemInstruction = fs.readFileSync(templatePath, "utf8");
} catch (error) {
  console.error(`Error: Could not read template file at ${templatePath}.`);
  console.error(error.message);
  process.exit(1);
}

const genAI = new GoogleGenerativeAI(apiKey);
const model = genAI.getGenerativeModel({
  model: modelName,
  systemInstruction: systemInstruction
});

// Function to handle retries for API calls
async function callGeminiApi(prompt) {
  const MAX_RETRIES = 5;
  let retryCount = 0;
  let delay = 2000; // Starting delay: 2 seconds

  while (retryCount <= MAX_RETRIES) {
    try {
      const result = await model.generateContent(prompt);
      const response = await result.response;
      return response.text();
    } catch (error) {
      const isRateLimit = error.message?.includes("429") || error.status === 429;

      if (isRateLimit && retryCount < MAX_RETRIES) {
        retryCount++;
        console.error(`Rate limit hit (429). Retrying in ${delay / 1000}s... (Attempt ${retryCount}/${MAX_RETRIES})`);
        await new Promise(resolve => setTimeout(resolve, delay));
        delay *= 2; // Exponential backoff
        continue;
      }

      console.error("Error calling Gemini API:", error.message);
      throw error; // Re-throw if not a rate limit or retries exhausted
    }
  }
  throw new Error("Failed to call Gemini API after multiple retries.");
}

async function getStdin() {
  let data = "";
  for await (const chunk of process.stdin) {
    data += chunk;
  }
  return data;
}

async function handlePipedInput() {
  const input = await getStdin();

  if (!input || input.trim() === "") {
    console.error("Error: No input provided on stdin for piped mode.");
    process.exit(1);
  }

  try {
    const responseText = await callGeminiApi(input);
    console.log(responseText.trim());
  } catch (error) {
    process.exit(1);
  }
}

async function handleInteractiveInput() {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
    prompt: '> '
  });

  console.log("Entering interactive mode. Type 'exit' or 'quit' to end the session.");
  console.log("Using gem: " + templatePath);
  console.log("Using model: " + modelName);

  // Initialize chat session for multi-turn conversations
  const chat = model.startChat({
    history: [],
    // You can add generation config here if needed
  });

  rl.prompt();

  rl.on('line', async (line) => {
    const userInput = line.trim();
    if (userInput.toLowerCase() === 'exit' || userInput.toLowerCase() === 'quit') {
      rl.close();
      return;
    }

    if (userInput === "") {
      rl.prompt();
      return;
    }

    try {
      const result = await chat.sendMessage(userInput); // Use chat.sendMessage for multi-turn
      const response = await result.response;
      const text = response.text();
      console.log(text.trim());
    } catch (error) {
      console.error("Error during interactive chat:", error.message);
      // Decide if you want to exit or continue after an error
    }
    rl.prompt();
  }).on('close', () => {
    console.log('Exiting interactive mode.');
    process.exit(0);
  });
}

async function main() {
  if (process.stdin.isTTY) {
    // Interactive mode
    await handleInteractiveInput();
  } else {
    // Piped input mode
    await handlePipedInput();
  }
}

main();
