#!/usr/bin/env node

const { Server } = require("@modelcontextprotocol/sdk/server/index.js");
const { StdioServerTransport } = require("@modelcontextprotocol/sdk/server/stdio.js");
const { CallToolRequestSchema, ListToolsRequestSchema } = require("@modelcontextprotocol/sdk/types.js");
const { execFile } = require("child_process");
const path = require("path");
const util = require("util");

const execFileAsync = util.promisify(execFile);

const server = new Server(
  {
    name: "mcp-gemini",
    version: "1.0.0",
  },
  {
    capabilities: {
      tools: {},
    },
  }
);

server.setRequestHandler(ListToolsRequestSchema, async () => {
  return {
    tools: [
      {
        name: "list_gemini_models",
        description: "List all available Gemini models for your configured API key.",
        inputSchema: {
          type: "object",
          properties: {},
          required: [],
        },
      },
    ],
  };
});

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  if (request.params.name === "list_gemini_models") {
    try {
      const zListScript = path.join(__dirname, "z-list-gemini-models");
      const { stdout, stderr } = await execFileAsync(process.execPath, [zListScript]);

      if (stderr && stderr.trim().length > 0 && !stdout) {
         return {
            content: [{ type: "text", text: `Error: ${stderr}` }],
            isError: true,
         };
      }

      return {
        content: [{ type: "text", text: stdout }],
      };
    } catch (error) {
      return {
        content: [{ type: "text", text: `Error executing tool: ${error.message}` }],
        isError: true,
      };
    }
  }

  throw new Error(`Tool not found: ${request.params.name}`);
});

async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

main().catch(console.error);
