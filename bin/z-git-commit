#!/usr/bin/env node

const { GoogleGenerativeAI } = require("@google/generative-ai");
const path = require("path");
const os = require("os");

// Load .env from the user's home directory
require("dotenv").config({ path: path.join(os.homedir(), ".env") });

// Load API key and model from environment variables
const apiKey = process.env.GEMINI_API_KEY;
const modelName = process.env.GEMINI_MODEL || "gemini-2.0-flash";

if (!apiKey) {
  console.error("Error: GEMINI_API_KEY is not set in your ~/.env file.");
  process.exit(1);
}

const genAI = new GoogleGenerativeAI(apiKey);
const model = genAI.getGenerativeModel({
  model: modelName,
  systemInstruction: `You are a helpful assistant that generates git commit messages based on git diffs.
Follow these rules:
1. Use the Conventional Commits format (e.g., 'feat: ...', 'fix: ...', 'docs: ...').
2. The first line MUST be a concise summary, ideally under 50 characters.
3. If the diff is large or complex, provide a detailed body (separated by a blank line) explaining the "why" and "how" of the changes.
4. For small, simple diffs, only provide the single-line summary.
5. Provide ONLY the commit message, nothing else.`
});

async function getStdin() {
  let data = "";
  for await (const chunk of process.stdin) {
    data += chunk;
  }
  return data;
}

async function main() {
  const diff = await getStdin();

  if (!diff || diff.trim() === "") {
    console.error("Error: No git diff provided on stdin.");
    process.exit(1);
  }

  const MAX_RETRIES = 5;
  let retryCount = 0;
  let delay = 2000; // Starting delay: 2 seconds

  while (retryCount <= MAX_RETRIES) {
    try {
      const result = await model.generateContent(diff);
      const response = await result.response;
      const commitMessage = response.text();
      console.log(commitMessage.trim());
      return; // Success!
    } catch (error) {
      const isRateLimit = error.message?.includes("429") || error.status === 429;
      
      if (isRateLimit && retryCount < MAX_RETRIES) {
        retryCount++;
        console.error(`Rate limit hit (429). Retrying in ${delay / 1000}s... (Attempt ${retryCount}/${MAX_RETRIES})`);
        await new Promise(resolve => setTimeout(resolve, delay));
        delay *= 2; // Exponential backoff
        continue;
      }

      console.error("Error calling Gemini API:", error.message);
      process.exit(1);
    }
  }
}

main();
