#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const os = require("os");
const readline = require("readline");
const { Ollama } = require("ollama");

// Load .env from the user's home directory
require("dotenv").config({ path: path.join(os.homedir(), ".env"), quiet: true });

// Load Host and model from environment variables
const ollamaHost = process.env.OLLAMA_HOST || "http://localhost:11434";
const modelName = process.env.OLLAMA_MODEL || "llama3.2";

const ollama = new Ollama({ host: ollamaHost });

// Determine template file path
const defaultTemplatePath = path.join(os.homedir(), ".z-gems", "tech-english-teacher");
const templatePath = process.argv[2] || defaultTemplatePath;

let systemInstruction = "";
try {
  systemInstruction = fs.readFileSync(templatePath, "utf8");
} catch (error) {
  console.error(`Error: Could not read template file at ${templatePath}.`);
  console.error(error.message);
  process.exit(1);
}

async function callOllamaApiStreaming(messages, captureResponse = false) {
  let fullResponse = "";
  try {
    const response = await ollama.chat({
      model: modelName,
      messages: messages,
      stream: true,
      think: true
    });

    let inThinking = false;

    for await (const part of response) {
      const thinking = part.message?.thinking;

      if (thinking && !inThinking) {
        inThinking = true

        if (captureResponse) {
          fullResponse += `\x1b[90m`;
        }
        process.stdout.write(`\x1b[90m`);
      }

      if (thinking) {
        if (captureResponse) {
          fullResponse += thinking;
        }
        process.stdout.write(thinking);
      }

      const content = part.message.content;
      if (content) {
        if (inThinking) {
          if (captureResponse) {
            fullResponse += `\x1b[0m\n`;
          }
          process.stdout.write(`\x1b[0m\n`);
          inThinking = false
        }

        if (captureResponse) {
          fullResponse += content;
        }
        process.stdout.write(content);
      }
    }
    
    process.stdout.write("\n");
    return captureResponse ? fullResponse : undefined;
  } catch (error) {
    if (error.message.includes("ECONNREFUSED")) {
      console.error(`Error: Could not connect to Ollama at ${ollamaHost}. Is Ollama running?`);
    } else {
      console.error("Error calling Ollama API:", error.message);
    }
    throw error;
  }
}

async function getStdin() {
  let data = "";
  for await (const chunk of process.stdin) {
    data += chunk;
  }
  return data;
}

async function handlePipedInput() {
  const input = await getStdin();

  if (!input || input.trim() === "") {
    console.error("Error: No input provided on stdin for piped mode.");
    process.exit(1);
  }

  try {
    const messages = [
      { role: "system", content: systemInstruction },
      { role: "user", content: input }
    ];
    await callOllamaApiStreaming(messages);
  } catch (error) {
    process.exit(1);
  }
}

async function handleInteractiveInput() {
  const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout,
    prompt: '> '
  });

  console.log("Entering interactive mode. Type 'exit' or 'quit' to end the session.");
  console.log("Using gem: " + templatePath);
  console.log("Using model: " + modelName + " at " + ollamaHost);

  const messages = [
    { role: "system", content: systemInstruction }
  ];

  rl.prompt();

  rl.on('line', async (line) => {
    const userInput = line.trim();
    if (userInput.toLowerCase() === 'exit' || userInput.toLowerCase() === 'quit') {
      rl.close();
      return;
    }

    if (userInput === "") {
      rl.prompt();
      return;
    }

    try {
      messages.push({ role: "user", content: userInput });
      const assistantResponse = await callOllamaApiStreaming(messages, true);
      messages.push({ role: "assistant", content: assistantResponse });
    } catch (error) {
      console.error("Error during interactive chat:", error.message);
      messages.pop();
    }
    rl.prompt();
  }).on('close', () => {
    console.log('Exiting interactive mode.');
    process.exit(0);
  });
}

async function main() {
  if (process.stdin.isTTY) {
    // Interactive mode
    await handleInteractiveInput();
  } else {
    // Piped input mode
    await handlePipedInput();
  }
}

main();
