#!/usr/bin/env node

const { GoogleGenerativeAI } = require("@google/generative-ai");
const path = require("path");
const os = require("os");

// Load .env from the user's home directory
require("dotenv").config({ path: path.join(os.homedir(), ".env") });

const apiKey = process.env.GEMINI_API_KEY;

if (!apiKey) {
  console.error("Error: GEMINI_API_KEY is not set in your ~/.env file.");
  process.exit(1);
}

// In the Node.js SDK, we use the listModels method via a specific client or raw fetch
// For simplicity and matching the SDK style, we'll use the REST endpoint
async function listModels() {
  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models?key=${apiKey}`
    );
    
    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }

    const data = await response.json();
    
    console.log("Available Gemini Models:");
    console.log("------------------------");
    
    data.models.forEach(model => {
      // Clean up the name (remove 'models/')
      const shortName = model.name.replace("models/", "");
      console.log(`- ${shortName.padEnd(30)} [${model.supportedGenerationMethods.join(", ")}]`);
    });
  } catch (error) {
    console.error("Error fetching models:", error.message);
    process.exit(1);
  }
}

listModels();
